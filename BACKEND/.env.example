# Database
DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/studynotesai

# Clerk
CLERK_SECRET_KEY=sk_test_xxx
CLERK_PUBLISHABLE_KEY=pk_test_xxx

# AI — ⚠️ MUST set in production for real AI responses
